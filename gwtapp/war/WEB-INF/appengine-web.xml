<?xml version="1.0" encoding="utf-8"?>
<appengine-web-app xmlns="http://appengine.google.com/ns/1.0">
  <!-- Modern App Engine Standard Environment Configuration -->
  <!-- Application ID is now managed via gcloud CLI, not in config -->
  
  <!-- Use Java 17 runtime for modern App Engine Standard -->
  <runtime>java17</runtime>
  
  <!-- Use smallest instance class for cost savings -->
  <instance-class>F1</instance-class>
  
  <!-- Enable automatic scaling -->
  <automatic-scaling>
    <min-instances>0</min-instances>
    <max-instances>2</max-instances>
    <min-idle-instances>0</min-idle-instances>
    <max-idle-instances>0</max-idle-instances>
    <target-cpu-utilization>0.8</target-cpu-utilization>
    <max-concurrent-requests>10</max-concurrent-requests>
  </automatic-scaling>

  <!-- Configure serving/caching of GWT files -->
  <!-- Security headers for modern browsers -->
  <static-files>
    <include path="**">
      <http-header name="X-Content-Type-Options" value="nosniff" />
      <http-header name="X-Frame-Options" value="DENY" />
      <http-header name="X-XSS-Protection" value="1; mode=block" />
    </include>

    <!-- GWT nocache files should never be cached -->
    <include path="**.nocache.*" expiration="0s" />
    <include path="**.nocache.*">
      <http-header name="Cache-Control" value="no-cache, no-store, must-revalidate" />
      <http-header name="Pragma" value="no-cache" />
      <http-header name="Expires" value="0" />
    </include>

    <!-- GWT cache files can be cached for a long time -->
    <include path="**.cache.*" expiration="365d" />
    <include path="**.cache.*">
      <http-header name="Cache-Control" value="public, max-age=31536000, immutable" />
    </include>
    
    <!-- Static assets caching -->
    <include path="**.css" expiration="7d" />
    <include path="**.js" expiration="7d" />
    <include path="**.png" expiration="30d" />
    <include path="**.jpg" expiration="30d" />
    <include path="**.gif" expiration="30d" />
    <include path="**.ico" expiration="30d" />
    <include path="**.mid" expiration="30d" />
    <include path="**.mp3" expiration="30d" />
    
    <!-- Exclude GWT RPC files from static serving -->
    <exclude path="**.gwt.rpc" />
  </static-files>

  <!-- Configure java.util.logging -->
  <system-properties>
    <property name="java.util.logging.config.file" value="WEB-INF/logging.properties"/>
  </system-properties>

  <!-- Enable sessions for user preferences (cookies) -->
  <sessions-enabled>true</sessions-enabled>

</appengine-web-app>
